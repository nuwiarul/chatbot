# Backend runtime config
RUST_LOG=info

# Server
HOST=127.0.0.1
PORT=8080

# Database
DATABASE_URL=postgres://chatbot:chatbot@127.0.0.1:5432/chatbot

# llama.cpp server
LLAMA_BASE_URL=http://127.0.0.1:9901

# Simple auth for API (Phase berikutnya)
API_KEY=dev-change-me

# CORS (comma-separated origins, or "*" for any)
# Example: CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGINS=*
